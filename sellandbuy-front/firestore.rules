rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Other collections rules could go here
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == userId 
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sellerRating', 'sellerRatingCount'])
      );
      allow create, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /products/{productId} {
      // Cualquiera puede leer productos, incluso no autenticados (opcional si es marketplace público)
      allow read: if true;
      
      // Solo usuarios logueados pueden crear, y su sellerId debe coincidir con su auth.uid
      allow create: if request.auth != null 
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.get('quantity', 1) >= 0;
      
      // Solo el dueño (seller) puede editar totalmente o terceros pueden actualizar métricas de rating
      allow update: if request.auth != null && (
        (resource.data.sellerId == request.auth.uid && request.resource.data.get('quantity', 1) >= 0)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount'])
      );
      
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;

      // --- COMMENTS SYSTEM ---
      match /comments/{commentId} {
        allow read: if true;
        // Solo el mismo usuario puede comentar, y su UID debe ser el ID del comentario para forzar un solo review
        allow create, update: if request.auth != null 
          && request.auth.uid == commentId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.rating >= 1 
          && request.resource.data.rating <= 5
          && request.resource.data.text.trim().size() > 0;
      }
    }

    // --- CHAT SYSTEM ---
    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
  }
}
