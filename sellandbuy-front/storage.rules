rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Reglas para imágenes de productos
    match /products/{userId}/{productId}/{allPaths=**} {
      // Todos pueden ver las imágenes de los productos
      allow read: if true;
      
      // Solo el usuario correspondiente puede subir o borrar imágenes en el directorio de sus productos
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
