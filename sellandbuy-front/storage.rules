rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Reglas para imágenes de productos
    match /products/{userId}/{productId}/{allPaths=**} {
      // Todos pueden ver las imágenes de los productos
      allow read: if true;
      
      // Solo el usuario correspondiente puede subir imágenes
      allow create, update: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
                            
      // Solo el usuario correspondiente puede borrar sus imágenes
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
